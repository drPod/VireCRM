# .env.example — env vars genesisxsx reads. Placeholders only.
#
# Keep in sync with `wrangler.jsonc` `vars` + CLAUDE.md "Secrets locations".
# `VITE_*` = public (shipped to browser). Live values committed in
# `.env.development` + `.env.production`. Real server-side secrets via
# `wrangler secret put <NAME>`, never committed.


# === PUBLIC (Vite-exposed) ===

VITE_SUPABASE_URL="https://REPLACE_ME.supabase.co"
VITE_SUPABASE_PROJECT_ID="REPLACE_ME"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_REPLACE_ME"

# Stripe publishable key. `pk_test_*` dev, `pk_live_*` prod. Provider-agnostic name.
VITE_PAYMENTS_CLIENT_TOKEN="pk_test_REPLACE_ME"


# === SUPABASE (server) ===

# Service-role JWT. Full DB bypass — admin paths only.
SUPABASE_SERVICE_ROLE_KEY="REPLACE_ME"


# === DATABASE (local dev only — prod uses Hyperdrive binding in wrangler.jsonc) ===

# `<project-ref>` e.g. `coynbufhejaeuifpvmvw`. `<password>` = Supabase DB password.
SUPABASE_DB_URL="postgres://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
SUPABASE_DB_URL_DIRECT="postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"
DATABASE_URL="postgres://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres"


# === STRIPE (server; Phase 6.5, deferred until customer #2) ===

STRIPE_LIVE_API_KEY="sk_live_REPLACE_ME"
PAYMENTS_LIVE_WEBHOOK_SECRET="whsec_REPLACE_ME"


# === MICROSOFT GRAPH (Outlook; Phase 5) ===

MS_GRAPH_CLIENT_ID="REPLACE_ME"
MS_GRAPH_CLIENT_SECRET="REPLACE_ME"


# === AI PROVIDERS ===

ANTHROPIC_API_KEY="sk-ant-api03-REPLACE_ME"


# === SENTRY (observability) ===

# Sentry DSN — public, write-only ingest endpoint. Empty = Sentry disabled.
# `VITE_SENTRY_DSN` is injected into the browser bundle by Vite.
# `SENTRY_DSN_PUBLIC` is read by the Worker (set in `wrangler.jsonc` `vars`).
VITE_SENTRY_DSN=""
SENTRY_DSN_PUBLIC=""

# Sentry source-map upload — `@sentry/vite-plugin` reads these at build time.
# All three needed together; if `SENTRY_AUTH_TOKEN` is empty the plugin no-ops
# (local dev + PR CI without secret still build clean).
# - `SENTRY_ORG`: slug from Sentry org URL (sentry.io/organizations/<slug>/)
# - `SENTRY_PROJECT`: project slug from Sentry settings
# - `SENTRY_AUTH_TOKEN`: org auth token w/ `project:releases` + `project:read`
#   scopes. Prod: `wrangler secret put SENTRY_AUTH_TOKEN`.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
