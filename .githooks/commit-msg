#!/usr/bin/env bash
# Conventional Commits gate. Pipes the commit-message file into commitlint.
#
# Wired via `git config core.hooksPath .githooks` — set by the `prepare`
# script in package.json on `bun install`.
#
# Skip merge / revert / fixup / squash commits where format isn't author-
# controlled. Bypass for genuine emergencies: git commit --no-verify
set -uo pipefail

case "$(head -n1 "$1")" in
  Merge*|Revert*|"fixup!"*|"squash!"*) exit 0 ;;
esac

bunx --bun commitlint --edit "$1"
