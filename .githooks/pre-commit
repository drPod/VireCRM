#!/usr/bin/env bash
# Pre-commit hook: lint ISSUES.md when staged.
#
# Catches orphan #### subsections, missing **Tags:** lines, and (warn) archive
# candidates >14d old. This is the hook the README of the project + CLAUDE.md
# point to — fires on any `git commit` that includes ISSUES.md changes.
#
# Skipped:
#  - Commits with no ISSUES.md in --cached set (fast path).
#  - Merge commits (MERGE_HEAD present) — lint already ran on the source branch's tip.
#  - Bypass: `git commit --no-verify` (use sparingly, per CLAUDE.md "no --no-verify").
#
# Installed via `scripts/install-hooks.sh` (sets core.hooksPath=.githooks).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Skip during merges — source branch should have linted.
if [[ -f .git/MERGE_HEAD ]]; then
  exit 0
fi

# Only run if ISSUES.md is in the staged set.
if ! git diff --cached --name-only --diff-filter=ACMR | grep -qx 'ISSUES.md'; then
  exit 0
fi

if [[ ! -x scripts/lint-issues.sh ]]; then
  echo "pre-commit: scripts/lint-issues.sh missing or not executable" >&2
  exit 1
fi

# Lint working-tree ISSUES.md. Partial-stage (git add -p) edge case: working tree
# may differ from staged content; we'd rather over-lint than skip. To strictly
# lint the staged blob: `git show :ISSUES.md | bash scripts/lint-issues.sh /dev/stdin`
# — defer until partial-stage becomes a real workflow.
if ! bash scripts/lint-issues.sh ISSUES.md; then
  cat >&2 <<EOF

pre-commit: ISSUES.md lint failed. See errors above.

Common fixes:
  - Orphan ####     → add `### YYYY-MM-DD — title` parent header above the block.
  - Missing tags    → add `**Tags:** [foo] [bar]` line directly below the date header.
  - Wrong hashes    → session headers are exactly three hashes (###), subsections four (####).

Full protocol: ISSUES.md "How to append". Bypass only with --no-verify (avoid).
EOF
  exit 1
fi
