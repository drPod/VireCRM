#!/usr/bin/env bash
# Cross-harness commit gate. Blocks ANY committer (human, Claude Code,
# Cursor, Aider, Copilot, ...) when the static contracts are violated.
#
# Wired via `git config core.hooksPath .githooks` — set by the `prepare`
# script in package.json on `bun install`.
#
# Runs the cheap gates locally. `check-build.sh` is deliberately left to
# CI — it's ~30s and would be intolerable on every commit. `check-worker-
# config.sh` ships under agent-check (Path B falls through to tsc when
# wrangler dry-run isn't available, which is the common dev case).
set -uo pipefail

repo="$(git rev-parse --show-toplevel)"
cd "${repo}"

echo "[pre-commit] static contract gate"

fail() {
  echo
  echo "pre-commit: BLOCKED — $1" >&2
  echo "            Bypass (only when you know what you're doing): git commit --no-verify" >&2
  exit 1
}

bash scripts/agent-check.sh || fail "typecheck failed"

# Only run schema-drift when a schema file is in the index — otherwise we
# pay the drizzle-kit cost on every commit for no reason.
if git diff --cached --name-only | grep -qE '^workers/db/schema/.+\.ts$|^drizzle/'; then
  bash scripts/check-schema-drift.sh || fail "schema drift — run 'bun run db:generate' and stage the result"
fi

# Only run worker-config check when wrangler.jsonc or workers/ TS is staged.
if git diff --cached --name-only | grep -qE '^wrangler\.jsonc$|^workers/.+\.ts$'; then
  bash scripts/check-worker-config.sh || fail "worker config / binding drift"
fi

# Warn-only: Biome lint/format on staged TS/TSX/JS/JSX. Trap non-zero so the
# commit isn't blocked while we're still in the rollout phase. Drop the `|| true`
# (and flip continue-on-error in checks.yml) to promote to blocking.
if git diff --cached --name-only --diff-filter=ACMR | grep -qE '\.(ts|tsx|js|jsx|cjs|mjs|cts|mts)$'; then
  echo "[pre-commit] biome (warn-only) on staged files"
  bunx --bun @biomejs/biome check --staged --no-errors-on-unmatched || true
fi

# Warn-only: gitleaks secret scan. The script self-skips when the binary
# isn't installed (most contributors); CI (.github/workflows/gitleaks.yml)
# is the enforced gate. Trap non-zero so a positive local detection warns
# but doesn't block — CI will block the PR. Install: `brew install gitleaks`.
echo "[pre-commit] gitleaks (warn-only)"
bash scripts/check-gitleaks.sh || true

echo "[pre-commit] all gates PASS"
