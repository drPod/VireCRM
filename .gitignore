# Foreign lockfiles — project is bun-only. Block accidental recreation
# by npm/pnpm/yarn (Lovable scaffold originally shipped a package-lock.json).
package-lock.json
pnpm-lock.yaml
yarn.lock

# Wrangler / Cloudflare
.wrangler/
.dev.vars
.dev.vars.*
.mf
worker-configuration.d.ts

# React Router v7 framework mode build output
/.react-router/
/build/
*.tsbuildinfo

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Playwright visual QA
/test-results/
/playwright-report/
/playwright/.cache/

# Secrets
.env
.env.local
.env.*.local
!.env.example

# Claude Code: ignore local state, but DO commit project-scoped skills,
# hooks, and settings.json so teammates share the same automations.
# settings.local.json stays ignored (per-user overrides).
.claude/*
!.claude/skills/
!.claude/hooks/
!.claude/settings.json

# Supabase CLI temp
supabase/.temp/

# Vercel
.vercel/

.vercel

# Customer data drops (xlsx/csv reseller imports — keep out of git)
*.xlsx
*.xls
*.csv

# Legacy Lovable Supabase dumps (auth.users with bcrypt hashes + PII).
# Used as reference for the old→new project data migration. NEVER push.
og_database/
*.sql.dump
*.pgdump
