{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/root.tsx",
    "app/routes/**/*.{ts,tsx}",
    "workers/app.ts",
    "vitest.config.ts",
    "react-router.config.ts",
    "scripts/inspect-xlsx.ts"
  ],
  "project": [
